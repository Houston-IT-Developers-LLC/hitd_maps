  "processing_pipeline": {
    "steps": [
      {
        "step": 1,
        "name": "download",
        "description": "Download source data to output/enrichment/raw/"
      },
      {
        "step": 2,
        "name": "validate_crs",
        "description": "Check coordinate system, reproject to WGS84 if needed"
      },
      {
        "step": 3,
        "name": "convert_format",
        "description": "Convert to GeoJSON if not already"
      },
      {
        "step": 4,
        "name": "generate_pmtiles",
        "description": "Generate PMTiles for map visualization (vector layers only)"
      },
      {
        "step": 5,
        "name": "upload_r2",
        "description": "Upload GeoJSON and PMTiles to Cloudflare R2"
      },
      {
        "step": 6,
        "name": "cleanup_local",
        "description": "Remove local files after successful upload"
      }
    ],
    "directory_structure": {
      "output/enrichment/raw/": "Original downloaded files",
      "output/enrichment/geojson/": "WGS84 GeoJSON files",
      "output/enrichment/pmtiles/": "Generated PMTiles",
