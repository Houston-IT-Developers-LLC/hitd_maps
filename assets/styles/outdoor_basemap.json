{
  "version": 8,
  "name": "HITD Outdoor Basemap",
  "metadata": {
    "description": "Outdoor-focused basemap for hunting and outdoor applications",
    "author": "Houston IT Developers LLC"
  },
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key={key}"
    },
    "terrain": {
      "type": "raster-dem",
      "url": "https://api.maptiler.com/tiles/terrain-rgb/tiles.json?key={key}",
      "tileSize": 256
    }
  },
  "sprite": "https://api.maptiler.com/maps/outdoor/sprite",
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key={key}",
  "terrain": {
    "source": "terrain",
    "exaggeration": 1.2
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#f8f4f0"
      }
    },
    {
      "id": "landcover-grass",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "grass"],
      "paint": {
        "fill-color": "#d8e8c8",
        "fill-opacity": 0.8
      }
    },
    {
      "id": "landcover-wood",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wood"],
      "paint": {
        "fill-color": "#a8d08d",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "landcover-scrub",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "scrub"],
      "paint": {
        "fill-color": "#c8d8b8",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "landuse-farmland",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landuse",
      "filter": ["==", "class", "farmland"],
      "paint": {
        "fill-color": "#eef0d5",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "park",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "park",
      "paint": {
        "fill-color": "#b8d9a0",
        "fill-opacity": 0.5
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-color": "#a0c8f0"
      }
    },
    {
      "id": "water-pattern",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "paint": {
        "fill-pattern": "wave",
        "fill-opacity": 0.1
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#a0c8f0",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 0.5,
          12, 2,
          16, 4
        ]
      }
    },
    {
      "id": "wetland",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "landcover",
      "filter": ["==", "class", "wetland"],
      "paint": {
        "fill-color": "#b8d8d0",
        "fill-opacity": 0.6
      }
    },
    {
      "id": "contour-line",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "contour",
      "paint": {
        "line-color": "#c0a080",
        "line-opacity": 0.4,
        "line-width": [
          "case",
          ["==", ["%", ["get", "ele"], 100], 0],
          1,
          0.5
        ]
      },
      "minzoom": 10
    },
    {
      "id": "contour-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "contour",
      "filter": ["==", ["%", ["get", "ele"], 200], 0],
      "layout": {
        "symbol-placement": "line",
        "text-field": "{ele}",
        "text-font": ["Noto Sans Regular"],
        "text-size": 9
      },
      "paint": {
        "text-color": "#a08060",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      },
      "minzoom": 12
    },
    {
      "id": "building",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "building",
      "paint": {
        "fill-color": "#d9d0c9",
        "fill-opacity": 0.7
      },
      "minzoom": 13
    },
    {
      "id": "building-outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "building",
      "paint": {
        "line-color": "#bbb5ae",
        "line-width": 0.5
      },
      "minzoom": 13
    },
    {
      "id": "road-path",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "path"],
      "paint": {
        "line-color": "#b08060",
        "line-width": 1,
        "line-dasharray": [2, 2]
      },
      "minzoom": 12
    },
    {
      "id": "road-track",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "track"],
      "paint": {
        "line-color": "#a08050",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 1,
          14, 2
        ],
        "line-dasharray": [4, 2]
      },
      "minzoom": 10
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "minor"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 1,
          14, 3,
          18, 6
        ]
      }
    },
    {
      "id": "road-minor-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "minor"],
      "paint": {
        "line-color": "#d0d0d0",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 2,
          14, 5,
          18, 9
        ]
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "road-secondary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "paint": {
        "line-color": "#ffffff",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 1,
          12, 3,
          16, 8
        ]
      }
    },
    {
      "id": "road-secondary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "secondary"],
      "paint": {
        "line-color": "#c0c0c0",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 2,
          12, 5,
          16, 12
        ]
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "road-primary",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#fcd6a4",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6, 1,
          10, 2,
          14, 6,
          18, 12
        ]
      }
    },
    {
      "id": "road-primary-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["==", "class", "primary"],
      "paint": {
        "line-color": "#e0a860",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6, 2,
          10, 4,
          14, 9,
          18, 16
        ]
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "road-motorway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "paint": {
        "line-color": "#fc8",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 1,
          10, 3,
          14, 8,
          18, 16
        ]
      }
    },
    {
      "id": "road-motorway-casing",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "filter": ["in", "class", "motorway", "trunk"],
      "paint": {
        "line-color": "#e68",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5, 2,
          10, 5,
          14, 12,
          18, 22
        ]
      },
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      }
    },
    {
      "id": "boundary-state",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 4],
      "paint": {
        "line-color": "#8080a0",
        "line-width": 1,
        "line-dasharray": [3, 2]
      },
      "minzoom": 4
    },
    {
      "id": "boundary-county",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "filter": ["==", "admin_level", 6],
      "paint": {
        "line-color": "#a0a0b0",
        "line-width": 0.5,
        "line-dasharray": [2, 2]
      },
      "minzoom": 8
    },
    {
      "id": "place-label-city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "city"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Bold"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6, 12,
          10, 18,
          14, 24
        ]
      },
      "paint": {
        "text-color": "#333333",
        "text-halo-color": "#ffffff",
        "text-halo-width": 2
      }
    },
    {
      "id": "place-label-town",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "town"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8, 10,
          12, 14,
          16, 18
        ]
      },
      "paint": {
        "text-color": "#444444",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1.5
      },
      "minzoom": 7
    },
    {
      "id": "place-label-village",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["==", "class", "village"],
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Regular"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 10,
          14, 12,
          18, 16
        ]
      },
      "paint": {
        "text-color": "#555555",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      },
      "minzoom": 10
    },
    {
      "id": "poi-park",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "poi",
      "filter": ["all", ["==", "class", "park"], ["has", "name"]],
      "layout": {
        "icon-image": "park",
        "text-field": "{name}",
        "text-font": ["Noto Sans Italic"],
        "text-size": 10,
        "text-offset": [0, 1.5],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#3a6d3a",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      },
      "minzoom": 12
    },
    {
      "id": "water-label",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "water_name",
      "layout": {
        "text-field": "{name}",
        "text-font": ["Noto Sans Italic"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10, 10,
          14, 14
        ]
      },
      "paint": {
        "text-color": "#4080a0",
        "text-halo-color": "#ffffff",
        "text-halo-width": 1
      },
      "minzoom": 8
    }
  ]
}
